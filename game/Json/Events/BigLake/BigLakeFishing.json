                      {
                          "NameOfScene": "EventStart",
                          "theScene": ["ChangeBGM-List",
                                            "music/Relaxing/Purple Planet Music - Gentle - Eastern Karma (2_16).mp3",
                                            "music/Relaxing/umi.mp3",
                                            "music/Relaxing/Purple Planet Music - Lanquidity (2 52) 110bpm.mp3",
